# Supabase credentials used by the browser app.
# Copy this file to .env.local and fill in your own project values.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Configure separately in Vercel for Production, Preview and Development.
# Production deployments require Supabase variables and demo login disabled.
VITE_ENABLE_DEMO_LOGIN="true"
VITE_DEMO_USER=""
VITE_DEMO_PASSWORD=""

# Server-only secrets used by the ARCA configuration panel in Sistema.
# Never use the public VITE_ prefix for these values.
SUPABASE_SERVICE_ROLE_KEY=""
# Generate with: openssl rand -base64 32
ARCA_CONFIG_ENCRYPTION_KEY=""

# Facturación electrónica ARCA (solo variables del servidor en Vercel).
# No usar prefijo VITE_: ese prefijo publica el valor dentro del navegador.
ARCA_CUIT=""
ARCA_PUNTO_VENTA="1"
ARCA_ENV="homologacion"
ARCA_CERT_BASE64=""
ARCA_KEY_BASE64=""
